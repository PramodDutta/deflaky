{
  "name": "deflaky-cli",
  "version": "1.1.2",
  "description": "Detect flaky tests by running your test suite multiple times. Works with Playwright, Selenium, Cypress, Jest, Pytest and any JUnit/JSON reporter.",
  "main": "dist/index.js",
  "bin": {
    "deflaky": "./bin/deflaky.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "flaky",
    "flaky-tests",
    "tests",
    "testing",
    "test-automation",
    "cli",
    "junit",
    "test-runner",
    "playwright",
    "selenium",
    "cypress",
    "jest",
    "pytest",
    "ci-cd",
    "test-reliability",
    "flakescore",
    "deflaky"
  ],
  "author": "Pramod Dutta <pramod@thetestingacademy.com> (https://thetestingacademy.com)",
  "license": "MIT",
  "homepage": "https://deflaky.com",
  "repository": {
    "type": "git",
    "url": "https://github.com/PramodDutta/deflaky.git",
    "directory": "cli"
  },
  "bugs": {
    "url": "https://github.com/PramodDutta/deflaky/issues"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "files": [
    "dist",
    "bin",
    "README.md"
  ],
  "dependencies": {
    "chalk": "^4.1.2",
    "cli-table3": "^0.6.5",
    "commander": "^14.0.3",
    "fast-xml-parser": "^5.5.10"
  },
  "devDependencies": {
    "@types/node": "^25.5.2",
    "typescript": "^6.0.2"
  }
}
